# oKidd Educational Platform - Environment Variables
# Copy this file to .env and fill in the real values

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/okidd

# Express Session (required)
SESSION_SECRET=your-very-long-random-secret-key-here-change-in-production

# Server (optional - defaults to 8080)
PORT=8080

# Frontend (optional)
NODE_ENV=development
