# ─────────────────────────────────────────────
#  oKidd — Production Environment Variables
# ─────────────────────────────────────────────
#  این فایل را به .env کپی کنید و مقادیر را پر کنید.
#  هرگز فایل .env را به git commit نکنید.
# ─────────────────────────────────────────────


# ── Database ──────────────────────────────────
# رشته اتصال PostgreSQL
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/okidd


# ── JWT Secret ────────────────────────────────
# این مقدار کلید رمزنگاری توکن‌های JWT است.
# هر کسی این رشته را داشته باشد می‌تواند جعل هویت کند — مخفی نگه دارید.
#
# برای ساخت یک رشته تصادفی امن در ترمینال:
#   openssl rand -base64 48
#
# مثال خروجی: Kx9mZ2vQpL8nR4wT7jY1fA3bE6cH0sD5uI2oN+XgW=
#
SESSION_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_-base64_48


# ── Server ────────────────────────────────────
NODE_ENV=production
PORT=8080

# مسیر base — روی سرور شخصی معمولاً / است
BASE_PATH=/


# ── CORS ──────────────────────────────────────
# دامنه سایت فرانت‌اند شما — در production حتماً تنظیم کنید
# بدون این مقدار: تمام cross-origin requestها رد می‌شوند
CORS_ORIGIN=https://your-domain.com
